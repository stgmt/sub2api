# Copy this file to .env before running docker compose.
# The setup skill script can generate this file for you.

# Headroom is the Claude Code-facing endpoint.
HEADROOM_VERSION=0.31.0
HEADROOM_PYTHON_VERSION=3.12
HEADROOM_BIND_HOST=127.0.0.1
HEADROOM_PORT=8787
SUB2API_STATE_ROOT=./data
HEADROOM_SAVINGS_PROFILE=agent-90
HEADROOM_TARGET_RATIO=0.10
HEADROOM_FORCE_KOMPRESS=1
HEADROOM_ACCURACY_GUARD=strict
HEADROOM_CODE_AWARE_ENABLED=1
HEADROOM_CONTEXT_TOOL=rtk
HEADROOM_RTK_GAIN_SCOPE=global
HEADROOM_COMPRESS_USER_MESSAGES=1
HEADROOM_COMPRESS_SYSTEM_MESSAGES=1
HEADROOM_PROTECT_ANALYSIS_CONTEXT=1
HEADROOM_PROTECT_READS=0
HEADROOM_PROTECT_RECENT=2
HEADROOM_MIN_TOKENS=120
HEADROOM_MAX_ITEMS=8
HEADROOM_DEDUPE=0
HEADROOM_TOOL_SEARCH=0
HEADROOM_LOSSLESS_THEN_LOSSY=0
HEADROOM_OUTPUT_SHAPER=1
HEADROOM_OUTPUT_HOLDOUT=0
HEADROOM_REQUEST_TIMEOUT_SECONDS=900
HEADROOM_ANTHROPIC_PRE_UPSTREAM_CONCURRENCY=8
HEADROOM_COMPRESSION_MAX_WORKERS=2
HEADROOM_KOMPRESS_EXECUTION_TIMEOUT_MS=60000
HEADROOM_COMPRESSION_TIMEOUT_SECONDS=120
HEADROOM_COMPRESSION_DEADLINE_MS=90000
HEADROOM_MID_TURN_STREAM_WAIT_MS=600000
HEADROOM_CLAUDE_CODE_HANDLER_WATCHDOG_MS=540000
HEADROOM_KOMPRESS_MAX_CONCURRENT=2
HEADROOM_KOMPRESS_ONNX_INTRA_THREADS=2
HEADROOM_KOMPRESS_ONNX_INTER_THREADS=1
HEADROOM_KOMPRESS_BATCH_SIZE=16

# sub2api stays exposed for admin UI, diagnostics, and non-Claude clients.
SUB2API_BIND_HOST=127.0.0.1
SUB2API_PORT=18081
SUB2API_IMAGE=sub2api-codex:local-token-usage
SUB2API_BUILD_CONTEXT=../..
SUB2API_DOCKERFILE=Dockerfile

TZ=UTC
RUN_MODE=simple
SIMPLE_MODE_CONFIRM=true
SERVER_MODE=release
LOG_LEVEL=info
DATA_DIR=/app/data
SECURITY_URL_ALLOWLIST_ALLOW_PRIVATE_HOSTS=true

ADMIN_EMAIL=admin@example.local
ADMIN_PASSWORD=change_this_admin_password

JWT_SECRET=change_this_to_a_long_random_jwt_secret
JWT_EXPIRE_HOUR=24
TOTP_ENCRYPTION_KEY=change_this_to_a_32_byte_or_longer_totp_key

POSTGRES_USER=sub2api
POSTGRES_PASSWORD=change_this_postgres_password
POSTGRES_DB=sub2api
DATABASE_MAX_OPEN_CONNS=50
DATABASE_MAX_IDLE_CONNS=10
DATABASE_CONN_MAX_LIFETIME_MINUTES=30
DATABASE_CONN_MAX_IDLE_TIME_MINUTES=5

REDIS_PASSWORD=change_this_redis_password
REDIS_DB=0
REDIS_POOL_SIZE=256
REDIS_MIN_IDLE_CONNS=10
REDIS_ENABLE_TLS=false
