ARG HEADROOM_PYTHON_VERSION=3.12
FROM python:${HEADROOM_PYTHON_VERSION}-slim AS headroom-base

ARG HEADROOM_VERSION=0.31.0
ARG HEADROOM_GIT_REPO=https://github.com/stgmt/headroom.git
ARG HEADROOM_GIT_REF=b9dfa2f76861ae9160d7e1fe4a151d2f92772284
ARG HEADROOM_RUST_TOOLCHAIN=1.88.0

LABEL org.opencontainers.image.source="${HEADROOM_GIT_REPO}" \
      org.opencontainers.image.revision="${HEADROOM_GIT_REF}" \
      org.opencontainers.image.title="stgmt Headroom for Claude Code through sub2api"

ENV PIP_NO_CACHE_DIR=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    HEADROOM_TELEMETRY=off \
    PATH="/root/.cargo/bin:${PATH}"

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates git build-essential curl pkg-config \
    && rm -rf /var/lib/apt/lists/*

RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
    | sh -s -- -y --profile minimal --default-toolchain "${HEADROOM_RUST_TOOLCHAIN}" \
    && rustc --version \
    && cargo --version

# Install the full local-runtime stack, not only the HTTP proxy. The MCP/CCR,
# code-aware compression, reports, OTEL, and bundled CLI tools are all used by
# the Claude Code profile and should survive image rebuilds.
RUN python -m pip install --upgrade pip \
    && python -m pip install "headroom-ai[proxy,code,relevance,html,spreadsheet,otel,reports,mcp] @ git+${HEADROOM_GIT_REPO}@${HEADROOM_GIT_REF}" \
    && python -c "import headroom; print('headroom', getattr(headroom, '__version__', 'unknown'), 'from', '${HEADROOM_GIT_REPO}', '${HEADROOM_GIT_REF}', 'expected-compatible-version', '${HEADROOM_VERSION}')" \
    && headroom tools install \
    && python -c "from headroom.rtk.installer import ensure_rtk; from headroom.lean_ctx.installer import ensure_lean_ctx; from headroom.graph.tokensave_installer import ensure_tokensave; print('rtk', ensure_rtk()); print('lean-ctx', ensure_lean_ctx()); print('tokensave', ensure_tokensave())"

COPY patch-headroom-embedding-server.py /tmp/patch-headroom-embedding-server.py
RUN python /tmp/patch-headroom-embedding-server.py
COPY patch-headroom-claude-code-streaming.py /tmp/patch-headroom-claude-code-streaming.py
RUN python /tmp/patch-headroom-claude-code-streaming.py
COPY start-headroom-proxy.sh /usr/local/bin/start-headroom-proxy
COPY benchmark-headroom-kompress.py /usr/local/bin/benchmark-headroom-kompress
RUN chmod +x /usr/local/bin/start-headroom-proxy /usr/local/bin/benchmark-headroom-kompress

RUN set -eux; \
    ln -sf /root/.headroom/bin/rtk /usr/local/bin/rtk; \
    ln -sf /root/.headroom/bin/lean-ctx /usr/local/bin/lean-ctx; \
    ln -sf /root/.local/bin/tokensave /usr/local/bin/tokensave; \
    difft_path="$(find /root/.cache/headroom/bin -type f -name difft | head -n 1)"; \
    scc_path="$(find /root/.cache/headroom/bin -type f -name scc | head -n 1)"; \
    test -n "$difft_path"; \
    test -n "$scc_path"; \
    ln -sf "$difft_path" /usr/local/bin/difft; \
    ln -sf "$scc_path" /usr/local/bin/scc; \
    rtk --version; \
    lean-ctx --version; \
    tokensave --version; \
    difft --version; \
    scc --version; \
    mkdir -p /opt/headroom-seed/headroom /opt/headroom-seed/cache-headroom /opt/headroom-seed/cache-huggingface; \
    cp -a /root/.headroom/. /opt/headroom-seed/headroom/; \
    cp -a /root/.cache/headroom/. /opt/headroom-seed/cache-headroom/; \
    if [ -d /root/.cache/huggingface ]; then cp -a /root/.cache/huggingface/. /opt/headroom-seed/cache-huggingface/; fi

WORKDIR /home/headroom

ENTRYPOINT ["/usr/local/bin/start-headroom-proxy"]
CMD ["--host", "0.0.0.0", "--port", "8787"]

# CUDA is opt-in so CPU-only installations keep the smaller image. The
# PyTorch backend is already implemented by Headroom and batches Kompress
# chunks on CUDA; compose selects this stage through docker-compose.gpu.yml.
FROM headroom-base AS gpu
ARG HEADROOM_TORCH_VERSION=2.11.0+cu128
ARG HEADROOM_TORCH_INDEX_URL=https://download.pytorch.org/whl/cu128
RUN python -m pip install "torch==${HEADROOM_TORCH_VERSION}" --index-url "${HEADROOM_TORCH_INDEX_URL}" \
    && python -c "import torch; assert torch.version.cuda; print('torch', torch.__version__, 'cuda', torch.version.cuda, 'build_gpu_visible', torch.cuda.is_available())"

# Keep this as the final stage so a plain `docker build` remains CPU-safe.
FROM headroom-base AS cpu
